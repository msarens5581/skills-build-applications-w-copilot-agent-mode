# OctoFit Tracker Frontend Environment Variables

# IMPORTANT: For GitHub Codespaces support, set your Codespace name here
# You can find your Codespace name in the URL: https://{CODESPACE_NAME}-5173.app.github.dev
VITE_CODESPACE_NAME=your-codespace-name

# Leave empty or comment out to use localhost:8000
# VITE_CODESPACE_NAME=
